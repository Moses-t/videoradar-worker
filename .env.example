# Base URL of the Lovable app (no trailing slash)
APP_BASE_URL=https://your-app.lovable.app

# Optional shared secret sent as x-api-secret header
API_SECRET=

# OpenAI API key for Whisper transcription
OPENAI_API_KEY=sk-...

# Poll interval in seconds
POLL_INTERVAL=10

# Whisper model
WHISPER_MODEL=whisper-1

# Optional: full Netscape-format cookies.txt contents for yt-dlp.
# Paste the entire file contents (including the "# Netscape HTTP Cookie File" header).
# If unset, yt-dlp runs without cookies.
YOUTUBE_COOKIES=
